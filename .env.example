# ==============================
# 朋友圈文案生成器 环境变量配置
# ==============================

# API Key（必填）
# 支持 OpenAI / 各类兼容 OpenAI 格式的代理服务
API_KEY=your_api_key_here

# API Base URL
API_BASE_URL=https://oneapi.hk/v1

# 主力模型（支持视觉，图片理解质量最好）
PRIMARY_MODEL=claude-sonnet-4-6

# 保底模型（速度快、成本低，主力失败时自动切换）
FALLBACK_MODEL=claude-haiku-4-5-20251001
